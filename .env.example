# Render Web Service
PORT=10000

# Where to put the SQLite file (Render Persistent Disk should be mounted at /var/data)
DB_PATH=/var/data/poker.db

# CORS: comma-separated list of allowed origins. Use "*" for any (Yandex Games frame).
ALLOWED_ORIGINS=*

# SSE heartbeat: ping every N ms to keep proxies (and Render's idle timeout) from killing the connection
SSE_HEARTBEAT_MS=15000